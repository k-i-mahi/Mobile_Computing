rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserDoc() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return hasUserDoc() && userDoc().data.role == 'ADMIN';
    }

    function isBanned() {
      return hasUserDoc() && userDoc().data.accountStatus == 'BANNED';
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function canUseApp() {
      return signedIn() && !isBanned();
    }

    function isValidUpvoteDelta() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['upvoteCount']) &&
        request.resource.data.upvoteCount is int &&
        request.resource.data.upvoteCount >= 0 &&
        (
          request.resource.data.upvoteCount == resource.data.upvoteCount + 1 ||
          request.resource.data.upvoteCount == resource.data.upvoteCount - 1
        );
    }

    function isValidDiscussionDelta() {
      let changed = request.resource.data.diff(resource.data).changedKeys();

      return (
        changed.hasOnly(['commentCount', 'updatedAt']) &&
        request.resource.data.commentCount is int &&
        request.resource.data.commentCount >= 0 &&
        (
          request.resource.data.commentCount == resource.data.commentCount + 1 ||
          request.resource.data.commentCount == resource.data.commentCount - 1 ||
          (!resource.data.keys().hasAny(['commentCount']) && request.resource.data.commentCount == 1)
        )
      ) || (
        changed.hasOnly(['commentCount', 'uniqueCommenterCount', 'updatedAt']) &&
        request.resource.data.commentCount is int &&
        request.resource.data.commentCount >= 0 &&
        request.resource.data.uniqueCommenterCount is int &&
        request.resource.data.uniqueCommenterCount >= 0 &&
        (
          request.resource.data.commentCount == resource.data.commentCount + 1 ||
          (!resource.data.keys().hasAny(['commentCount']) && request.resource.data.commentCount == 1)
        ) &&
        (
          request.resource.data.uniqueCommenterCount == resource.data.uniqueCommenterCount + 1 ||
          (!resource.data.keys().hasAny(['uniqueCommenterCount']) && request.resource.data.uniqueCommenterCount == 1)
        )
      ) || (
        changed.hasOnly(['replyCount', 'updatedAt']) &&
        request.resource.data.replyCount is int &&
        request.resource.data.replyCount >= 0 &&
        (
          request.resource.data.replyCount == resource.data.replyCount + 1 ||
          request.resource.data.replyCount == resource.data.replyCount - 1 ||
          (!resource.data.keys().hasAny(['replyCount']) && request.resource.data.replyCount == 1)
        )
      );
    }

    function isValidCommentReplyDelta() {
      let changed = request.resource.data.diff(resource.data).changedKeys();

      return changed.hasOnly(['replyCount']) &&
        request.resource.data.replyCount is int &&
        request.resource.data.replyCount >= 0 &&
        (
          request.resource.data.replyCount == resource.data.replyCount + 1 ||
          request.resource.data.replyCount == resource.data.replyCount - 1 ||
          (!resource.data.keys().hasAny(['replyCount']) && request.resource.data.replyCount == 1)
        );
    }

    function canCreateReport() {
      return canUseApp() &&
        request.resource.data.reporterUid == request.auth.uid &&
        request.resource.data.status == 'OPEN' &&
        (
          (
            request.resource.data.targetType == 'EVENT' &&
            exists(/databases/$(database)/documents/events/$(request.resource.data.targetId)) &&
            get(/databases/$(database)/documents/events/$(request.resource.data.targetId)).data.creatorUid != request.auth.uid
          ) ||
          (
            request.resource.data.targetType == 'COMMENT' &&
            request.resource.data.eventId is string &&
            exists(/databases/$(database)/documents/events/$(request.resource.data.eventId)/comments/$(request.resource.data.targetId)) &&
            get(/databases/$(database)/documents/events/$(request.resource.data.eventId)/comments/$(request.resource.data.targetId)).data.authorUid != request.auth.uid
          ) ||
          (
            request.resource.data.targetType == 'REPLY' &&
            request.resource.data.eventId is string &&
            request.resource.data.parentCommentId is string &&
            exists(/databases/$(database)/documents/events/$(request.resource.data.eventId)/comments/$(request.resource.data.parentCommentId)/replies/$(request.resource.data.targetId)) &&
            get(/databases/$(database)/documents/events/$(request.resource.data.eventId)/comments/$(request.resource.data.parentCommentId)/replies/$(request.resource.data.targetId)).data.authorUid != request.auth.uid
          )
        );
    }

    function eventPath(eventId) {
      return /databases/$(database)/documents/events/$(eventId);
    }

    function commentPath(eventId, commentId) {
      return /databases/$(database)/documents/events/$(eventId)/comments/$(commentId);
    }

    function replyPath(eventId, commentId, replyId) {
      return /databases/$(database)/documents/events/$(eventId)/comments/$(commentId)/replies/$(replyId);
    }

    function validClientNotification(uid) {
      return canUseApp() &&
        request.resource.data.actorUid == request.auth.uid &&
        request.resource.data.eventId is string &&
        request.resource.data.eventTitle is string &&
        request.resource.data.kind is string &&
        request.resource.data.message is string &&
        request.resource.data.dedupeKey is string &&
        (
          (
            request.resource.data.kind == 'NEW_COMMENT_ON_YOUR_EVENT' &&
            request.resource.data.targetCommentId is string &&
            exists(eventPath(request.resource.data.eventId)) &&
            get(eventPath(request.resource.data.eventId)).data.creatorUid == uid &&
            exists(commentPath(request.resource.data.eventId, request.resource.data.targetCommentId)) &&
            get(commentPath(request.resource.data.eventId, request.resource.data.targetCommentId)).data.authorUid == request.auth.uid
          ) ||
          (
            request.resource.data.kind == 'REPLY_TO_YOUR_COMMENT' &&
            request.resource.data.targetCommentId is string &&
            request.resource.data.targetReplyId is string &&
            exists(commentPath(request.resource.data.eventId, request.resource.data.targetCommentId)) &&
            get(commentPath(request.resource.data.eventId, request.resource.data.targetCommentId)).data.authorUid == uid &&
            exists(replyPath(request.resource.data.eventId, request.resource.data.targetCommentId, request.resource.data.targetReplyId)) &&
            get(replyPath(request.resource.data.eventId, request.resource.data.targetCommentId, request.resource.data.targetReplyId)).data.authorUid == request.auth.uid
          ) ||
          (
            request.resource.data.kind == 'UPVOTE_ON_YOUR_EVENT' &&
            exists(eventPath(request.resource.data.eventId)) &&
            get(eventPath(request.resource.data.eventId)).data.creatorUid == uid &&
            exists(/databases/$(database)/documents/events/$(request.resource.data.eventId)/upvotes/$(request.auth.uid))
          ) ||
          (
            request.resource.data.kind == 'EVENT_DETAILS_CHANGED' &&
            exists(eventPath(request.resource.data.eventId)) &&
            (get(eventPath(request.resource.data.eventId)).data.creatorUid == request.auth.uid || isAdmin()) &&
            exists(/databases/$(database)/documents/event_notification_subscribers/$(request.resource.data.eventId)/users/$(uid)) &&
            get(/databases/$(database)/documents/event_notification_subscribers/$(request.resource.data.eventId)/users/$(uid)).data.isEnabled == true
          )
        );
    }

    match /account_registry/{email} {
      allow get: if true;
      allow list: if false;
      allow create: if signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == email;
      allow update: if signedIn() &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.uid == resource.data.uid &&
        resource.data.email == email &&
        request.resource.data.email == email;
      allow delete: if false;
    }

    match /users/{uid} {
      allow read: if signedIn() && (owns(uid) || isAdmin());
      allow create: if signedIn() && owns(uid);
      allow update: if signedIn() && !isBanned() && (owns(uid) || isAdmin());
      allow delete: if false;
    }

    match /events/{eventId} {
      allow read: if canUseApp() && (
        resource.data.status == 'APPROVED' ||
        resource.data.isApproved == true ||
        resource.data.creatorUid == request.auth.uid ||
        isAdmin()
      );

      allow create: if canUseApp() && (
        (request.resource.data.creatorUid == request.auth.uid && request.resource.data.status in ['DRAFT', 'PENDING_APPROVAL']) ||
        isAdmin()
      );

      allow update: if canUseApp() && (
        isAdmin() ||
        (resource.data.creatorUid == request.auth.uid && !(resource.data.status in ['REMOVED_BY_ADMIN', 'ARCHIVED'])) ||
        isValidUpvoteDelta() ||
        isValidDiscussionDelta()
      );

      allow delete: if isAdmin();

      match /upvotes/{uid} {
        allow read: if canUseApp();
        allow create, delete: if canUseApp() && owns(uid);
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if canUseApp();
        allow create: if canUseApp() && (!hasUserDoc() || userDoc().data.accountStatus != 'COMMENT_RESTRICTED');
        allow update, delete: if canUseApp() && (
          resource.data.authorUid == request.auth.uid ||
          isAdmin() ||
          isValidCommentReplyDelta()
        );

        match /replies/{replyId} {
          allow read: if canUseApp();
          allow create: if canUseApp() && (!hasUserDoc() || userDoc().data.accountStatus != 'COMMENT_RESTRICTED');
          allow update, delete: if canUseApp() && (
            resource.data.authorUid == request.auth.uid || isAdmin()
          );
        }
      }

      match /commenters/{uid} {
        allow read: if canUseApp();
        allow create: if canUseApp() && owns(uid);
        allow update, delete: if false;
      }
    }

    match /{path=**}/comments/{commentId} {
      allow read: if canUseApp();
    }

    match /{path=**}/replies/{replyId} {
      allow read: if canUseApp();
    }

    match /reports/{reportId} {
      allow create: if canCreateReport();
      allow read: if canUseApp() && (resource.data.reporterUid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /moderation_cases/{caseId} {
      allow create: if canUseApp() &&
        request.resource.data.reporterUid == request.auth.uid &&
        request.resource.data.status == 'OPEN';
      allow read: if canUseApp() &&
        (resource.data.reporterUid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /warnings/{warningId} {
      allow read: if canUseApp() && (resource.data.userUid == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /restrictions/{restrictionId} {
      allow read: if canUseApp() && (resource.data.userUid == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /admin_actions/{actionId} {
      allow read, write: if isAdmin();
    }

    match /notice_board_items/{noticeId} {
      allow read: if canUseApp();
      allow write: if isAdmin();
    }

    match /notice_sources/{sourceId} {
      allow read: if canUseApp();
      allow write: if isAdmin();
    }

    match /gmail_connection_settings/{uid} {
      allow read, write: if canUseApp() && (owns(uid) || isAdmin());
    }

    match /synced_gmail_notice_items/{uid}/items/{itemId} {
      allow read, write: if canUseApp() && (owns(uid) || isAdmin());
    }

    match /event_notification_subscribers/{eventId}/users/{uid} {
      allow read: if canUseApp() && (
        owns(uid) ||
        isAdmin() ||
        resource.data.eventCreatorUid == request.auth.uid
      );
      allow create, update: if canUseApp() && owns(uid);
      allow delete: if false;
    }

    match /user_event_reminders/{uid}/items/{reminderId} {
      allow read: if canUseApp() && (
        owns(uid) ||
        isAdmin() ||
        resource.data.eventCreatorUid == request.auth.uid
      );
      allow write: if canUseApp() && (owns(uid) || isAdmin());
    }

    match /user_notifications/{uid}/items/{itemId} {
      allow read, delete: if canUseApp() && (owns(uid) || isAdmin());
      allow create, update: if canUseApp() && (
        owns(uid) ||
        isAdmin() ||
        validClientNotification(uid)
      );
    }

    match /organizations_or_clubs/{orgId} {
      allow read: if canUseApp();
      allow write: if isAdmin();
    }
  }
}
